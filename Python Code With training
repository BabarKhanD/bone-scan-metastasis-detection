print("\nGenerating hotspot detection with bounding boxes...")

def detect_hotspot(ant_img, post_img, model, last_conv_layer,
                   true_label, pred_prob, threshold=0.5):
    ant_input  = ant_img[np.newaxis, ...]
    post_input = post_img[np.newaxis, ...]

    heatmap = make_gradcam_heatmap(
        [ant_input, post_input], model, last_conv_layer, "ant_input"
    )
    heatmap_resized = np.array(
        tf.image.resize(heatmap[..., np.newaxis], (128, 128))
    ).squeeze()
    heatmap_norm = (heatmap_resized - heatmap_resized.min()) / \
                   (heatmap_resized.max() - heatmap_resized.min() + 1e-8)

    binary_map = (heatmap_norm > threshold).astype(np.uint8)
    contours, _ = cv2.findContours(
        binary_map, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE
    )

    fig, axes = plt.subplots(1, 3, figsize=(12, 4))

    axes[0].imshow(ant_img.squeeze(), cmap='gray')
    axes[0].set_title(f'ANT Image\nTrue: {true_label}')
    axes[0].axis('off')

    axes[1].imshow(ant_img.squeeze(), cmap='gray')
    axes[1].imshow(heatmap_norm, cmap='jet', alpha=0.4)
    axes[1].set_title(f'Grad-CAM\nPred prob: {pred_prob:.2f}')
    axes[1].axis('off')

    axes[2].imshow(ant_img.squeeze(), cmap='gray')
    axes[2].imshow(heatmap_norm, cmap='jet', alpha=0.3)

    if contours:
        largest = max(contours, key=cv2.contourArea)
        x, y, w, h = cv2.boundingRect(largest)
        rect = patches.Rectangle((x, y), w, h,
                                  linewidth=2, edgecolor='red', facecolor='none')
        axes[2].add_patch(rect)
