def check_single_image(filename):
    """
    Enter any image filename (e.g. '1234.jpg') to get full analysis.
    Works for both ANT and POST views.
    """
    ant_path  = f"{ANT_PATH}/{filename}"
    post_path = f"{POST_PATH}/{filename}"

    if not os.path.exists(ant_path):
        print(f"Image {filename} not found!")
        return

    # Load and preprocess
    ant_img  = preprocess_image(ant_path)[..., np.newaxis]
    post_img = preprocess_image(post_path)[..., np.newaxis]

    # Get true label
    true_label = labels_ant.get(filename, "Unknown")

    # Get predictions from all models
    ant_4d  = ant_img[np.newaxis, ...]
    post_4d = post_img[np.newaxis, ...]

    prob_baseline = model_baseline.predict([ant_4d, post_4d], verbose=0)[0][0]
    prob_aug      = model_aug.predict([ant_4d, post_4d], verbose=0)[0][0]
    prob_focal    = model_focal.predict([ant_4d, post_4d], verbose=0)[0][0]
    prob_vit      = model_vit.predict([ant_4d, post_4d], verbose=0)[0][0]

    pred_focal = "🔴 METASTASIS" if prob_focal > 0.25 else "🟢 No Metastasis"

    print(f"\n{'='*50}")
    print(f"Image: {filename}")
    print(f"True Label: {'Metastasis' if true_label == 1 else 'No Metastasis'}")
    print(f"{'='*50}")
    print(f"Baseline CNN   : {prob_baseline:.3f} → "
          f"{'Metastasis' if prob_baseline > 0.5 else 'No Metastasis'}")
    print(f"Augmented CNN  : {prob_aug:.3f} → "
          f"{'Metastasis' if prob_aug > 0.5 else 'No Metastasis'}")
    print(f"Focal Loss CNN : {prob_focal:.3f} → {pred_focal}")
    print(f"ViT            : {prob_vit:.3f} → "
          f"{'Metastasis' if prob_vit > 0.5 else 'No Metastasis'}")
    print(f"{'='*50}")

    # Full visualization
    original, nlm_img, enhanced, norm_img = \
        full_preprocessing_pipeline(ant_img)

    heatmap = make_gradcam_heatmap(
        [ant_4d, post_4d], model_focal, last_conv, "ant_input"
    )
    heatmap_resized = np.array(
        tf.image.resize(heatmap[..., np.newaxis], (128, 128))
    ).squeeze()
    heatmap_norm = (heatmap_resized - heatmap_resized.min()) / \
                   (heatmap_resized.max() - heatmap_resized.min() + 1e-8)

    # Bounding box
    binary_map = (heatmap_norm > 0.5).astype(np.uint8)
    contours, _ = cv2.findContours(
        binary_map, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE
    )

    fig, axes = plt.subplots(1, 5, figsize=(20, 4))

    axes[0].imshow(original, cmap='gray')
    axes[0].set_title(f'Original\n{filename}')
    axes[0].axis('off')

    axes[1].imshow(nlm_img, cmap='gray')
    axes[1].set_title('NLM Denoised')
    axes[1].axis('off')

    axes[2].imshow(enhanced, cmap='gray')
    axes[2].set_title('CLAHE Enhanced')
    axes[2].axis('off')

    axes[3].imshow(ant_img.squeeze(), cmap='gray')
    axes[3].imshow(heatmap_norm, cmap='jet', alpha=0.4)
    axes[3].set_title(f'Grad-CAM\nProb: {prob_focal:.2f}')
    axes[3].axis('off')

    axes[4].imshow(ant_img.squeeze(), cmap='gray')
    axes[4].imshow(heatmap_norm, cmap='jet', alpha=0.3)
    if contours:
        largest = max(contours, key=cv2.contourArea)
        x, y, w, h = cv2.boundingRect(largest)
        rect = patches.Rectangle((x, y), w, h, linewidth=2,
                                  edgecolor='red', facecolor='none')
        axes[4].add_patch(rect)
    axes[4].set_title(f'Detection\n{pred_focal}')
    axes[4].axis('off')

    true_str = 'Metastasis' if true_label == 1 else 'No Metastasis'
    plt.suptitle(f'Full Analysis: {filename} | True: {true_str} | '
                 f'Predicted: {pred_focal}',
                 fontsize=12, fontweight='bold')
    plt.tight_layout()
    plt.show()

