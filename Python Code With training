    post_input = post_img[np.newaxis, ...]

    # Get preprocessed image
    original, nlm_img, enhanced, norm_img = \
        full_preprocessing_pipeline(ant_img)

    # Get Grad-CAM
    heatmap = make_gradcam_heatmap(
        [ant_input, post_input], model, last_conv_layer, "ant_input"
    )
    heatmap_resized = np.array(
        tf.image.resize(heatmap[..., np.newaxis], (128, 128))
    ).squeeze()
    heatmap_norm = (heatmap_resized - heatmap_resized.min()) / \
                   (heatmap_resized.max() - heatmap_resized.min() + 1e-8)

    fig, axes = plt.subplots(1, 4, figsize=(16, 4))

    axes[0].imshow(original, cmap='gray')
    axes[0].set_title(f'Original\nLabel: {true_label}')
    axes[0].axis('off')

    axes[1].imshow(nlm_img, cmap='gray')
    axes[1].set_title('NLM Denoised')
    axes[1].axis('off')

    axes[2].imshow(enhanced, cmap='gray')
    axes[2].set_title('CLAHE Enhanced')
    axes[2].axis('off')

    axes[3].imshow(ant_img.squeeze(), cmap='gray')
    axes[3].imshow(heatmap_norm, cmap='jet', alpha=0.4)
    axes[3].set_title(f'Grad-CAM\nPred: {pred_prob:.2f}')
    axes[3].axis('off')

    pred_label = "Metastasis" if pred_prob > 0.25 else "No Metastasis"
    plt.suptitle(f'Full Analysis — True: {true_label} | Predicted: {pred_label}',
                 fontsize=13, fontweight='bold')
    plt.tight_layout()
    plt.show()

