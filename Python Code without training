        print(f"  Label not found for {filename}")
        return

    img_4d = img[np.newaxis, ...]

    # Get prediction using both views (always feed both; we just display requested view)
    # For the selected view, use itself as proxy for both inputs to still get a valid prediction
    prob = float(model.predict([img_4d, img_4d], verbose=0)[0][0])

    title_str = format_title(true_label, prob, threshold)
    original, _, enhanced, _ = full_preprocessing_pipeline(img)

    # Grad-CAM on same view for both inputs
    heatmap_norm = get_heatmap_norm(img, img, model, last_conv_layer)

    fig, axes = plt.subplots(1, 4, figsize=(18, 4))

    # 1. Original
    axes[0].imshow(original, cmap='gray')
    axes[0].set_title(f'Original ({view_label})\n{filename}')
    axes[0].axis('off')

    # 2. Enhanced
    axes[1].imshow(enhanced, cmap='gray')
    axes[1].set_title(f'Enhanced ({view_label})\nCLAHE')
    axes[1].axis('off')

    # 3. Heatmap — hotspot rule
    axes[2].imshow(img.squeeze(), cmap='gray')
    if true_label == 1:
        axes[2].imshow(heatmap_norm, cmap='jet', alpha=0.5)
        axes[2].set_title(f'Heatmap — Red Hotspot\nProb: {prob:.2f}')
    else:
        axes[2].imshow(heatmap_norm, cmap='Blues', alpha=0.4)
        axes[2].set_title(f'Heatmap — No Hotspot\nProb: {prob:.2f}')
    axes[2].axis('off')

    # 4. Bounding box
    axes[3].imshow(img.squeeze(), cmap='gray')
    if true_label == 1:
        axes[3].imshow(heatmap_norm, cmap='jet', alpha=0.3)
    else:
        axes[3].imshow(heatmap_norm, cmap='Blues', alpha=0.3)

    binary_map = (heatmap_norm > 0.5).astype(np.uint8)
    contours, _ = cv2.findContours(binary_map, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    if contours and true_label == 1:
        largest = max(contours, key=cv2.contourArea)
        x, y, w, h = cv2.boundingRect(largest)
        rect = patches.Rectangle((x, y), w, h, linewidth=2,
                                  edgecolor='red', facecolor='none')
        axes[3].add_patch(rect)
        axes[3].set_title(f'Bounding Box\n({x},{y}) {w}×{h}px')
    else:
        axes[3].set_title('Bounding Box\n(No lesion)')
    axes[3].axis('off')

    plt.suptitle(f'[{view_label}] {title_str}', fontsize=12, fontweight='bold')
    plt.tight_layout()
    plt.show()

    # Accuracy graph
    plot_accuracy_bar(true_label, prob, threshold)


def check_image_interactive(filename, view_mode):
    """
    view_mode: 1 = ANT only, 2 = POST only, 3 = BOTH
    """
    ant_path  = f"{ANT_PATH}/{filename}"
    post_path = f"{POST_PATH}/{filename}"

    ant_exists  = os.path.exists(ant_path)
    post_exists = os.path.exists(post_path)

    if not ant_exists and not post_exists:
        print(f"  ❌ Image '{filename}' not found in ANT or POST directories.")
        return

    if view_mode in [1, 3] and ant_exists:
        ant_img = preprocess_image(ant_path)[..., np.newaxis]
        print(f"\n--- ANT View: {filename} ---")
        run_single_view(ant_img, labels_ant, "ANT", filename,
                        model_focal, last_conv)

    if view_mode in [2, 3] and post_exists:
        post_img = preprocess_image(post_path)[..., np.newaxis]
        print(f"\n--- POST View: {filename} ---")
        run_single_view(post_img, labels_post, "POST", filename,
                        model_focal, last_conv)

    if view_mode == 1 and not ant_exists:
        print(f"  ⚠️  ANT image not found for '{filename}'.")
    if view_mode == 2 and not post_exists:
        print(f"  ⚠️  POST image not found for '{filename}'.")


