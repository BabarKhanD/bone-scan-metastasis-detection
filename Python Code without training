def preprocess_image(path, size=(128, 128)):
    img = Image.open(path).convert("L")
    img = img.resize(size)
    img = np.array(img) / 255.0
    return img

def full_preprocessing_pipeline(img_array):
    img_uint8 = (img_array.squeeze() * 255).astype(np.uint8)
    nlm = cv2.fastNlMeansDenoising(img_uint8, h=15,
          templateWindowSize=7, searchWindowSize=21)
    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(4, 4))
    enhanced = clahe.apply(nlm)
    norm = cv2.normalize(enhanced, None, 0, 255, cv2.NORM_MINMAX)
    return img_uint8, nlm, enhanced, norm

