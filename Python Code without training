    """
    original, nlm_img, enhanced, norm_img = full_preprocessing_pipeline(ant_img)
    heatmap_norm = get_heatmap_norm(ant_img, post_img, model, last_conv_layer)

    title_str = format_title(true_label, pred_prob, threshold)

    fig, axes = plt.subplots(1, 4, figsize=(18, 4))

    # Panel 1 — Original
    axes[0].imshow(original, cmap='gray')
    axes[0].set_title('Original Image')
    axes[0].axis('off')

    # Panel 2 — CLAHE Enhanced (single enhanced version)
    axes[1].imshow(enhanced, cmap='gray')
    axes[1].set_title('Enhanced Image (CLAHE)')
    axes[1].axis('off')

    # Panel 3 — Heatmap with hotspot rule
    axes[2].imshow(ant_img.squeeze(), cmap='gray')
    if true_label == 1:
        # Cancer case → show red hotspot regions
        axes[2].imshow(heatmap_norm, cmap='jet', alpha=0.5)
        axes[2].set_title(f'Heatmap — Red Hotspot\nProb: {pred_prob:.2f}')
    else:
        # Non-cancer case → plain heatmap, no red hotspot overlay
        axes[2].imshow(heatmap_norm, cmap='Blues', alpha=0.4)
        axes[2].set_title(f'Heatmap — No Hotspot\nProb: {pred_prob:.2f}')
    axes[2].axis('off')

    # Panel 4 — Heatmap + bounding box
    axes[3].imshow(ant_img.squeeze(), cmap='gray')
    if true_label == 1:
        axes[3].imshow(heatmap_norm, cmap='jet', alpha=0.4)
    else:
        axes[3].imshow(heatmap_norm, cmap='Blues', alpha=0.3)

    binary_map = (heatmap_norm > 0.5).astype(np.uint8)
    contours, _ = cv2.findContours(binary_map, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    if contours and true_label == 1:
        largest = max(contours, key=cv2.contourArea)
        x, y, w, h = cv2.boundingRect(largest)
        rect = patches.Rectangle((x, y), w, h, linewidth=2,
                                  edgecolor='red', facecolor='none')
        axes[3].add_patch(rect)
        axes[3].set_title(f'Bounding Box\nBox: ({x},{y}) {w}×{h}px')
    else:
        axes[3].set_title('Bounding Box\n(No lesion region)')
    axes[3].axis('off')

    plt.suptitle(title_str, fontsize=13, fontweight='bold')
    plt.tight_layout()
    plt.show()

    # Always show accuracy graph
    plot_accuracy_bar(true_label, pred_prob, threshold)


